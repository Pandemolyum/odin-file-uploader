<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Files</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <%- include("partials/header.ejs") %>

    <h1>Files</h1>

    <% if (isConnected) { %>
    <form action="/files/upload" enctype="multipart/form-data" method="post" id="upload-form">
        <div class="form-group">
            <input type="file" class="form-control-file" name="uploaded_file">
            <input type="submit" value="Upload" class="btn btn-default">
        </div>
    </form>

    <!-- NEW FOLDER BUTTON -->
    <div class="create-folder-section" style="margin-bottom: 20px;">
        <form action="/folders/create" method="POST" id="create-form">
            <input type="text" name="folderName" placeholder="New folder name" required>
            <button type="submit">New Folder</button>
        </form>
    </div>

    <!-- CURRENT PATH -->
    <div class="currentPath">
        <% paths.forEach((path, i) => { %>
        <span class="pathLink">/<a class="pathLink" href="<%= path %>"><%= segments[i] %></a></span>
        <% }); %>
    </div>

    <!-- FILES AND FOLDERS TABLE -->
    <% if (files.length !== 0 || folders.length !== 0) { %>
    <table>
        <thead>
            <tr>
                <th>Name</th>
                <th>Size (bytes)</th>
                <th>Creation Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <!-- FOLDERS -->
            <% folders.forEach((folder) => { %>
            <tr id="folder-<%= folder.id %>">
                <td>
                    <div class="folder-display">
                        <a class="folder-link" href="<%= folder.path %>/<%= folder.name %>"><span
                                class="folder-text"><%= folder.name %></span></a>
                        <button onclick="toggleRenameFolder('<%= folder.id %>')">Rename</button>
                    </div>
                    <form class="folder-edit" style="display:none;" action="/folders/<%= folder.id %>/rename"
                        method="POST">
                        <input type="text" name="newName" value="<%= folder.name %>" required>
                        <button type="submit">Save</button>
                        <button type="button" onclick="toggleRenameFolder('<%= folder.id %>')">Cancel</button>
                    </form>
                </td>
                <td>-</td>
                <td><%= folder.createdAt.toLocaleString() %></td>
                <td>
                    <div style="display: flex; gap: 5px;">
                        <% if (folder.shareLinkExpDate === null || folder.shareLinkExpDate < new Date()) { %>
                        <a href="/folders/<%= folder.id %>/share"><button class="share">Create Share Link</button></a>
                        <% } else { %>
                        <button class="share" onclick="copyToClipboard('<%= folder.shareLink %>')">Copy Share
                            Link</button>
                        <% } %>
                        <form class="folder-delete" action="/folders/<%= folder.id %>/delete" method="POST">
                            <button type="submit" class="delete">Delete</button>
                        </form>
                    </div>
                </td>
            </tr>
            <% }); %>

            <!-- FILES -->
            <% files.forEach((file) => { %>
            <tr id="file-<%= file.id %>">
                <td>
                    <div class="file-display">
                        <span class="filename-text"><%= file.name %></span>
                        <button onclick="toggleRenameFile('<%= file.id %>')">Rename</button>
                    </div>
                    <form class="file-edit" style="display:none;" action="/files/<%= file.id %>/rename" method="POST">
                        <input type="text" name="newName" value="<%= file.name %>" required>
                        <button type="submit">Save</button>
                        <button type="button" onclick="toggleRenameFile('<%= file.id %>')">Cancel</button>
                    </form>
                </td>
                <td><%= file.size %></td>
                <td><%= file.uploadedAt.toLocaleString() %></td>
                <td>
                    <div style="display: flex; gap: 5px;">
                        <a href="<%= file.link %>"><button class="download">Download</button></a>
                        <form class="file-delete" action="/files/<%= file.id %>/delete" method="POST">
                            <button type="submit" class="delete">Delete</button>
                        </form>
                    </div>
                </td>
            </tr>
            <% }); %>
        </tbody>
    </table>
    <% } else { %>
    <div class="file-error">No files have been uploaded in this location.</div>
    <% } %>

    <% } else { %>
    <div class="file-error"><a href="/login">Login</a> to upload and view files</div>
    <% } %>

</body>

<script>
    const form_names = ["upload-form", "create-form"];

    form_names.forEach((form) => {
        document.getElementById(form).addEventListener('submit', function (e) {
            e.preventDefault(); // Stop immediate submission

            // Get the current route
            const currentRoute = window.location.pathname;

            // Create a hidden input
            const routeInput = document.createElement('input');
            routeInput.type = 'hidden';
            routeInput.name = 'user_route';
            routeInput.value = currentRoute;

            // Append to form and submit
            this.appendChild(routeInput);
            this.submit();
        });
    });

    function toggleRenameFile(fileId) {
        const container = document.getElementById(`file-${fileId}`);
        const display = container.querySelector('.file-display');
        const edit = container.querySelector('.file-edit');

        // Toggle visibility
        const isHidden = edit.style.display === 'none';
        edit.style.display = isHidden ? 'block' : 'none';
        display.style.display = isHidden ? 'none' : 'block';
    }

    function toggleRenameFolder(folderId) {
        const container = document.getElementById(`folder-${folderId}`);
        const display = container.querySelector('.folder-display');
        const edit = container.querySelector('.folder-edit');

        // Toggle visibility
        const isHidden = edit.style.display === 'none';
        edit.style.display = isHidden ? 'block' : 'none';
        display.style.display = isHidden ? 'none' : 'block';
    }

    function copyToClipboard(copyText) {
        console.log(copyText);
        navigator.clipboard.writeText(copyText)
            .then(() => {
                alert("Text copied to clipboard: " + copyText);
            })
            .catch(err => {
                console.error("Failed to copy text: ", err);
            });
    }
</script>

</html>